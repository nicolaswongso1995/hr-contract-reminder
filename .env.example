# ============================================================
# HR Contract Reminder - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Application
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-change-this

# Admin Credentials (fallback auth)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=your-secure-admin-password

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Talenta / Mekari API ─────────────────────────────────────
TALENTA_BASE_URL=https://api.mekari.com
TALENTA_CLIENT_ID=your-talenta-client-id
TALENTA_CLIENT_SECRET=your-talenta-client-secret
TALENTA_COMPANY_ID=your-talenta-company-id

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM="HR System <hr@company.com>"
EMAIL_TO=hr-team@company.com

# ── WhatsApp Integration ──────────────────────────────────────
# Supports Fonnte, WA Cloud API, or custom webhook
WHATSAPP_PROVIDER=fonnte
WHATSAPP_API_URL=https://api.fonnte.com/send
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_SENDER_NUMBER=628xxxxxxxxxx

# ── Cron / Scheduler ─────────────────────────────────────────
CRON_SECRET=your-secret-token-for-cron-endpoint
CRON_SCHEDULE="0 8 * * *"

# ── Feature Flags ─────────────────────────────────────────────
USE_MOCK_DATA=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false
