# ============================================================
# HR Contract Reminder — HRIS Integration Config
# Copy to hris/.env and fill in your values
# ============================================================

# ── Mekari Talenta API ────────────────────────────────────────
# Get these from: developer.mekari.com → Your Apps → Credentials
TALENTA_CLIENT_ID=your-client-id-here
TALENTA_CLIENT_SECRET=your-client-secret-here
TALENTA_COMPANY_ID=your-company-id-here
TALENTA_BASE_URL=https://api.mekari.com

# ── Gmail SMTP ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=wongso.nicolas75@gmail.com
SMTP_APP_PASSWORD=your-16-char-app-password

# ── Email Recipients ──────────────────────────────────────────
EMAIL_FROM=HR Contract System <wongso.nicolas75@gmail.com>
EMAIL_TO=nicolas@thomasong.co.id
# Comma-separated CC list (optional)
EMAIL_CC=

# ── Report Settings ───────────────────────────────────────────
COMPANY_NAME=PT Thomas Ong Indonesia
# How many days ahead to include in the weekly report
REPORT_DAYS_AHEAD=30
